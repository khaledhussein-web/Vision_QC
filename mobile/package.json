{
  "name": "visionqc-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\" && expo start",
    "mobile": "npm --prefix .. run mobile",
    "start:all": "npm --prefix .. run start:all",
    "start:all:lan": "npm --prefix .. run start:all:lan",
    "start:all:tunnel": "npm --prefix .. run start:all:tunnel",
    "android": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\" && expo run:android",
    "ios": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\" && expo run:ios",
    "web": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\" && expo start --web",
    "lint": "echo \"Add eslint config if needed\""
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-image-picker": "~17.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0"
  }
}
